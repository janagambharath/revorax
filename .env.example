# =============================================================
# REVORAX — Environment Variables
# Copy this file to .env in each app/package and fill values
# =============================================================

# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/revorax?schema=public"

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth (Better Auth) ──────────────────────────────────────
BETTER_AUTH_SECRET="your-super-secret-key-min-32-chars-change-in-prod"
BETTER_AUTH_URL="http://localhost:3000"

# ─── API ─────────────────────────────────────────────────────
API_URL="http://localhost:3001"
API_PORT=3001
CORS_ORIGIN="http://localhost:3000"

# ─── Web App ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Revorax"

# ─── AI Providers ────────────────────────────────────────────
# Primary provider: openai | anthropic | groq | gemini | openrouter
AI_PRIMARY_PROVIDER="openai"
AI_FALLBACK_PROVIDER="groq"

OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-3-5-haiku-20241022"

GROQ_API_KEY="gsk_..."
GROQ_MODEL="llama-3.1-70b-versatile"

GEMINI_API_KEY="AIza..."
GEMINI_MODEL="gemini-2.0-flash"

OPENROUTER_API_KEY="sk-or-..."
OPENROUTER_MODEL="meta-llama/llama-3.1-70b-instruct"

# ─── WhatsApp (Meta Cloud API) ───────────────────────────────
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_BUSINESS_ACCOUNT_ID="your-waba-id"
WHATSAPP_ACCESS_TOKEN="your-permanent-access-token"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="your-random-webhook-verify-token"
WHATSAPP_API_VERSION="v21.0"

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="Revorax <noreply@revorax.online>"
EMAIL_REPLY_TO="support@revorax.online"

# ─── Billing (Razorpay) ──────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_..."

# ─── Storage (Cloudflare R2) ─────────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret"
R2_BUCKET_NAME="revorax-storage"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# ─── Logging / Monitoring ────────────────────────────────────
SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
LOG_LEVEL="info"
NODE_ENV="development"
