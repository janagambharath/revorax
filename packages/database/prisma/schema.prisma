// This is your Prisma schema file for Revorax — AI Revenue OS
// Multi-tenant, multi-vertical B2B SaaS platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum BusinessType {
  GYM
  CLINIC
  SALON
  COACHING
  REAL_ESTATE
  DENTAL
  AGENCY
  OTHER
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
}

enum Plan {
  STARTER
  GROWTH
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
  UNPAID
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  TRIAL
  CONVERTED
  LOST
  NURTURING
}

enum LeadSource {
  WALK_IN
  REFERRAL
  WEBSITE
  SOCIAL_MEDIA
  COLD_CALL
  CAMPAIGN
  PARTNER
  OTHER
}



enum MemberStatus {
  ACTIVE
  TRIAL
  EXPIRED
  FROZEN
  CANCELLED
}

enum MembershipType {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  ANNUAL
  DAY_PASS
  CUSTOM
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED
  REFUNDED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  RAZORPAY
  OTHER
}

enum MessageChannel {
  WHATSAPP
  EMAIL
  SMS
  IN_APP
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
  PAUSED
}

enum TemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
  REMINDER
  FOLLOW_UP
  RENEWAL
  WELCOME
  CUSTOM
}

enum WorkflowTrigger {
  MEMBER_EXPIRY_3_DAYS
  MEMBER_EXPIRY_7_DAYS
  MEMBER_EXPIRY_TODAY
  MEMBER_EXPIRED
  LEAD_CREATED
  TRIAL_STARTED
  PAYMENT_OVERDUE
  APPOINTMENT_REMINDER
  MANUAL
  CAMPAIGN
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  INVITE
  SEND_MESSAGE
  CAMPAIGN_SENT
  PAYMENT_RECORDED
  MEMBER_STATUS_CHANGED
  WORKFLOW_TRIGGERED
}

// ─── Core: Organization (Tenant) ─────────────────────────────────────────────

model Organization {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  businessType BusinessType @default(GYM)
  logoUrl      String?
  phone        String?
  email        String?
  address      String?
  city         String?
  country      String       @default("IN")
  timezone     String       @default("Asia/Kolkata")
  currency     String       @default("INR")
  settings     Json         @default("{}")
  plan         Plan         @default(STARTER)
  isActive     Boolean      @default(true)
  trialEndsAt  DateTime?
  whatsappPhoneNumberId String?
  whatsappAccessToken   String?
  whatsappBusinessId    String?
  whatsappVerified      Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  // Relations
  users         User[]
  contacts      Contact[]
  leads         Lead[]
  notes         Note[]
  tasks         Task[]
  messages      Message[]
  members       Member[]
  patients      Patient[]
  clients       Client[]
  payments      Payment[]
  campaigns     Campaign[]
  templates     Template[]
  workflows     Workflow[]
  auditLogs     AuditLog[]
  subscription  Subscription?
  inviteTokens  InviteToken[]

  @@index([slug])
  @@index([businessType])
  @@index([deletedAt])
  @@map("organizations")
}

// ─── Core: Users ─────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  orgId        String
  email        String
  name         String
  passwordHash String
  role         UserRole  @default(STAFF)
  avatarUrl    String?
  phone        String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  emailVerifiedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // Relations
  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions     Session[]
  assignedLeads Lead[]       @relation("LeadAssignee")
  notes        Note[]
  tasks        Task[]
  auditLogs    AuditLog[]
  campaigns    Campaign[]

  @@unique([orgId, email])
  @@index([orgId])
  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model InviteToken {
  id        String    @id @default(cuid())
  orgId     String
  email     String
  role      UserRole  @default(STAFF)
  token     String    @unique @default(cuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([orgId])
  @@map("invite_tokens")
}

// ─── CRM: Contacts ───────────────────────────────────────────────────────────

model Contact {
  id          String    @id @default(cuid())
  orgId       String
  name        String
  phone       String?
  email       String?
  avatarUrl   String?
  tags        String[]  @default([])
  source      LeadSource @default(OTHER)
  city        String?
  notes       String?
  customFields Json     @default("{}")
  isActive    Boolean   @default(true)
  whatsappOptIn Boolean @default(true)
  unsubscribedAt DateTime?  // DND/opt-out compliance
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  leads        Lead[]
  notesList    Note[]
  tasks        Task[]
  messages     Message[]
  member       Member?
  patient      Patient?
  client       Client?
  campaignRecipients CampaignRecipient[]

  @@index([orgId])
  @@index([phone])
  @@index([email])
  @@index([deletedAt])
  @@map("contacts")
}

// ─── CRM: Leads ──────────────────────────────────────────────────────────────

model Lead {
  id           String     @id @default(cuid())
  orgId        String
  contactId    String
  assignedToId String?
  status       LeadStatus @default(NEW)
  source       LeadSource @default(OTHER)
  score        Int        @default(0)
  notes        String?
  lostReason   String?
  convertedAt  DateTime?
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  // Relations
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id])
  assignedTo   User?        @relation("LeadAssignee", fields: [assignedToId], references: [id])

  @@index([orgId])
  @@index([status])
  @@index([assignedToId])
  @@index([deletedAt])
  @@map("leads")
}

// ─── CRM: Notes ──────────────────────────────────────────────────────────────

model Note {
  id          String   @id @default(cuid())
  orgId       String
  contactId   String
  createdById String
  body        String
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact     Contact      @relation(fields: [contactId], references: [id])
  createdBy   User         @relation(fields: [createdById], references: [id])

  @@index([orgId])
  @@index([contactId])
  @@index([deletedAt])
  @@map("notes")
}

// ─── CRM: Tasks ──────────────────────────────────────────────────────────────

model Task {
  id          String    @id @default(cuid())
  orgId       String
  contactId   String?
  createdById String
  title       String
  description String?
  status      String    @default("PENDING") // PENDING | COMPLETED
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdBy   User         @relation(fields: [createdById], references: [id])

  @@index([orgId])
  @@index([contactId])
  @@index([deletedAt])
  @@map("tasks")
}

// ─── Messaging ───────────────────────────────────────────────────────────────

model Message {
  id           String           @id @default(cuid())
  orgId        String
  contactId    String
  channel      MessageChannel
  direction    MessageDirection
  body         String
  status       MessageStatus    @default(QUEUED)
  externalId   String?          // WhatsApp message ID, email ID etc.
  templateId   String?
  campaignId   String?
  metadata     Json             @default("{}")
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  failedAt     DateTime?
  failReason   String?
  createdAt    DateTime         @default(now())

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id])
  template     Template?    @relation(fields: [templateId], references: [id])
  campaign     Campaign?    @relation(fields: [campaignId], references: [id])

  @@index([orgId])
  @@index([contactId])
  @@index([channel])
  @@index([status])
  @@index([sentAt])
  @@map("messages")
}

// ─── Gym Vertical: Members ───────────────────────────────────────────────────

model Member {
  id             String         @id @default(cuid())
  orgId          String
  contactId      String         @unique
  memberCode     String?
  membershipType MembershipType @default(MONTHLY)
  status         MemberStatus   @default(TRIAL)
  startDate      DateTime
  renewalDate    DateTime
  endDate        DateTime?
  amount         Decimal        @db.Decimal(10, 2)
  paidAmount     Decimal        @default(0) @db.Decimal(10, 2)
  followUpStatus String         @default("PENDING") // PENDING | DONE | SCHEDULED
  lastContactedAt DateTime?
  reactivationAttempts Int      @default(0)
  churnScore     Int?           // 0-100, AI-calculated churn risk
  goals          String?        // GYM: fitness goals
  healthNotes    String?        // GYM/CLINIC/DENTAL: health info
  missedCount    Int            @default(0) // CLINIC/DENTAL: missed appointments
  visitCount     Int            @default(0) // SALON: total visits
  averageSpend   Decimal?       @db.Decimal(10, 2) // SALON/AGENCY: avg spend
  dealValue      Decimal?       @db.Decimal(12, 2) // REAL_ESTATE/AGENCY: deal size
  assignedStaffId String?
  notes          String?
  metadata       Json           @default("{}") // Niche-specific extra fields
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  org            Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact        Contact        @relation(fields: [contactId], references: [id])
  payments       Payment[]

  @@index([orgId])
  @@index([status])
  @@index([renewalDate])
  @@index([deletedAt])
  @@map("members")
}

model Payment {
  id          String        @id @default(cuid())
  orgId       String
  memberId    String
  amount      Decimal       @db.Decimal(10, 2)
  status      PaymentStatus @default(PENDING)
  method      PaymentMethod @default(CASH)
  dueDate     DateTime?
  paidAt      DateTime?
  receiptNo   String?
  notes       String?
  razorpayId  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  org         Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  member      Member        @relation(fields: [memberId], references: [id])

  @@index([orgId])
  @@index([memberId])
  @@index([status])
  @@index([dueDate])
  @@map("payments")
}

// ─── Clinic Vertical: Patients ───────────────────────────────────────────────

model Patient {
  id                    String        @id @default(cuid())
  orgId                 String
  contactId             String        @unique
  patientCode           String?
  status                String        @default("ACTIVE") // ACTIVE | INACTIVE | RECALL
  lastAppointmentDate   DateTime
  nextAppointmentDate   DateTime?
  missedAppointmentCount Int          @default(0)
  treatmentValue        Decimal       @db.Decimal(10, 2)
  lastRecallDate        DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  deletedAt             DateTime?

  org                   Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact               Contact       @relation(fields: [contactId], references: [id])

  @@index([orgId])
  @@index([status])
  @@index([deletedAt])
  @@map("patients")
}

// ─── Salon Vertical: Clients ─────────────────────────────────────────────────

model Client {
  id              String        @id @default(cuid())
  orgId           String
  contactId       String        @unique
  status          String        @default("ACTIVE") // ACTIVE | INACTIVE | LAPSED
  lastVisitDate   DateTime
  nextBookingDate DateTime?
  averageSpend    Decimal       @db.Decimal(10, 2)
  visitCount      Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  org             Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact         Contact       @relation(fields: [contactId], references: [id])

  @@index([orgId])
  @@index([status])
  @@index([deletedAt])
  @@map("clients")
}

// ─── Templates ───────────────────────────────────────────────────────────────

model Template {
  id              String           @id @default(cuid())
  orgId           String
  name            String
  channel         MessageChannel
  category        TemplateCategory @default(CUSTOM)
  subject         String?          // for email
  body            String
  variables       String[]         @default([]) // e.g. ["{{name}}", "{{renewal_date}}"]
  whatsappName    String?          // approved template name on Meta
  whatsappStatus  String?          // PENDING | APPROVED | REJECTED
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  org             Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  messages        Message[]
  campaignTemplates Campaign[]

  @@unique([orgId, name, channel])
  @@index([orgId])
  @@index([deletedAt])
  @@map("templates")
}

// ─── Campaigns ───────────────────────────────────────────────────────────────

model Campaign {
  id             String         @id @default(cuid())
  orgId          String
  createdById    String
  name           String
  channel        MessageChannel
  templateId     String?
  customBody     String?
  status         CampaignStatus @default(DRAFT)
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  recipientCount Int            @default(0)
  sentCount      Int            @default(0)
  deliveredCount Int            @default(0)
  failedCount    Int            @default(0)
  audienceFilter Json           @default("{}")
  metadata       Json           @default("{}")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  org            Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy      User               @relation(fields: [createdById], references: [id])
  template       Template?          @relation(fields: [templateId], references: [id])
  recipients     CampaignRecipient[]
  messages       Message[]

  @@index([orgId])
  @@index([status])
  @@index([scheduledAt])
  @@index([deletedAt])
  @@map("campaigns")
}

model CampaignRecipient {
  id         String        @id @default(cuid())
  campaignId String
  contactId  String
  status     MessageStatus @default(QUEUED)
  messageId  String?
  sentAt     DateTime?
  error      String?
  createdAt  DateTime      @default(now())

  campaign   Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact    Contact       @relation(fields: [contactId], references: [id])

  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@index([status])
  @@map("campaign_recipients")
}

// ─── Automation: Workflows ────────────────────────────────────────────────────

model Workflow {
  id          String          @id @default(cuid())
  orgId       String
  name        String
  description String?
  trigger     WorkflowTrigger
  steps       Json            // array of step definitions
  isActive    Boolean         @default(true)
  lastRunAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  org         Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  jobs        WorkflowJob[]

  @@index([orgId])
  @@index([trigger])
  @@index([isActive])
  @@index([deletedAt])
  @@map("workflows")
}

model WorkflowJob {
  id          String    @id @default(cuid())
  workflowId  String
  contactId   String?
  memberId    String?
  status      String    @default("PENDING") // PENDING | RUNNING | COMPLETED | FAILED | SKIPPED
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  error       String?
  log         Json      @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([status])
  @@index([scheduledAt])
  @@map("workflow_jobs")
}

// ─── Billing ─────────────────────────────────────────────────────────────────

model Subscription {
  id                 String             @id @default(cuid())
  orgId              String             @unique
  plan               Plan               @default(STARTER)
  status             SubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  razorpaySubId      String?
  razorpayCustomerId String?
  metadata           Json               @default("{}")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  org                Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("subscriptions")
}


// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditLog {
  id        String      @id @default(cuid())
  orgId     String
  userId    String?
  action    AuditAction
  entity    String      // "Member", "Lead", "Campaign", etc.
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User?        @relation(fields: [userId], references: [id])

  @@index([orgId])
  @@index([userId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
