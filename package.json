{
  "name": "revorax",
  "version": "0.1.0",
  "private": true,
  "description": "Revorax — AI Revenue OS for growing businesses",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:migrate": "pnpm --filter database migrate:dev",
    "db:push": "pnpm --filter database db:push",
    "db:seed": "pnpm --filter database seed",
    "db:studio": "pnpm --filter database studio",
    "clean": "turbo run clean && rimraf node_modules",
    "start": "turbo run start"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": "22.x",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.2"
}
