# ── App ──────────────────────────────────────────────
APP_ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/revorax

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ─────────────────────────────────────────────
JWT_SECRET_KEY=change-me-generate-a-random-64-char-string

# ── Twilio ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── AI / LLM (OpenRouter) ───────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# ── Speech-to-Text (Groq) ───────────────────────────
GROQ_API_KEY=

# ── Email (Resend) ──────────────────────────────────
RESEND_API_KEY=

# ── Payments (Stripe) ──────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_SETUP_FEE_PRICE_ID=

# ── Storage (Cloudflare R2) ─────────────────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=revorax-recordings
R2_ENDPOINT_URL=

# ── Monitoring ──────────────────────────────────────
SENTRY_DSN=
